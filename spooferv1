local function RunScript(Config)
    getgenv().Config = Config
    -- Force global variable to prevent nil errors
    getgenv().KeyAuthApp = nil 

    -- [GUI SETUP] --
    local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/nfpw/XXSCRIPT/refs/heads/main/Library/Module.lua"))()
    local window = library:CreateWindow({
        Color = Color3.fromRGB(255, 255, 255),
        Keybind = Enum.KeyCode.RightShift,
        Assets = false,
        MinHeight = 45, MaxHeight = 250, InitialHeight = 300,
        MinWidth = 250, MaxWidth = 900, InitialWidth = 460,
    }, gethui())

    library:SetWindowName("Cloakhook | Loading Auth...")

    -- [KEYAUTH INITIALIZATION] --
    task.spawn(function()
        local success, KeyAuth = pcall(function() 
            return loadstring(game:HttpGet("https://raw.githubusercontent.com/KeyAuth/new-keyauth-lua-lib/main/library.lua"))() 
        end)

        if success then
            local app = KeyAuth.new(Config.name, Config.ownerid, Config.secret, Config.version)
            local initSuccess, err = pcall(function() app:init() end)
            
            if initSuccess then
                getgenv().KeyAuthApp = app
                library:SetWindowName("Cloakhook | Ready")
                print("KeyAuth: Initialized successfully.")
            else
                warn("KeyAuth Init Failed: " .. tostring(err))
            end
        else
            warn("KeyAuth Library Load Failed: " .. tostring(KeyAuth))
        end
    end)

    -- [TABS] --
    local tabs = {
        auth = window:CreateTab("Auth"),
        spoofer = window:CreateTab("Spoofer"),
    }

    -- [AUTH TAB] --
    local inputKey = ""
    tabs.auth:CreateSection("Key Verification"):CreateTextBox("License Key", "Paste key here", function(val) inputKey = val end)
    tabs.auth:CreateSection("Actions"):CreateButton("Login", function()
        if getgenv().KeyAuthApp then
            getgenv().KeyAuthApp:license(inputKey)
            if getgenv().KeyAuthApp.response == "Logged in!" then
                window:Notify("Cloakware", "Access Granted", 3)
                library:SetWindowName("Cloakhook | Authenticated")
            else
                window:Notify("Cloakware", "Error: " .. tostring(getgenv().KeyAuthApp.response), 3)
            end
        else
            window:Notify("Cloakware", "System Not Ready Yet!", 3)
        end
    end)

    -- [SPOOFER TAB] --
    tabs.spoofer:CreateSection("Profile Spoofer"):CreateButton("Apply Config", function()
        if getgenv().KeyAuthApp and getgenv().KeyAuthApp.response == "Logged in!" then
            pcall(function() loadstring(game:HttpGet("https://raw.githubusercontent.com/WEFGQERQEGWGE/a/refs/heads/main/UDRCRFRAMESCRIPT.lua"))() end)
            window:Notify("Cloakware", "Config Applied", 3)
        else
            window:Notify("Cloakware", "Login Required", 3)
        end
    end)
end

return RunScript
