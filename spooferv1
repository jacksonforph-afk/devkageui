local function RunScript(Config)
    -- [CONFIGURATION] --
    local REQUIRED_KEY = "devkage" -- CHANGE THIS TO WHATEVER KEY YOU WANT

    -- [1] MANUAL KEYAUTH LIB INJECTION --
    local KeyAuth = {}
    KeyAuth.__index = KeyAuth
    function KeyAuth.new(name, ownerid, secret, version)
        local self = setmetatable({}, KeyAuth)
        self.name = name; self.ownerid = ownerid; self.secret = secret; self.version = version
        self.response = "Not Initialized"
        return self
    end
    function KeyAuth:init()
        self.response = "Initialized" -- Changed from "Logged in!" to show it's ready for the key
        print("KeyAuth Initialized Manually")
    end
    function KeyAuth:license(key)
        if key == REQUIRED_KEY then 
            self.response = "Logged in!"
        else
            self.response = "Invalid Key"
        end
    end
    getgenv().KeyAuthApp = KeyAuth.new(Config.name, Config.ownerid, Config.secret, Config.version)
    getgenv().KeyAuthApp:init()

    -- [2] UI SETUP --
    local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/nfpw/XXSCRIPT/refs/heads/main/Library/Module.lua"))()
    local window = library:CreateWindow({
        Color = Color3.fromRGB(255, 255, 255),
        Keybind = Enum.KeyCode.RightShift,
    }, gethui())

    library:SetWindowName("Cloakhook | Manual Inject")
    window:Notify("Cloakware", "System Ready!", 3)

    -- [3] TABS --
    local tabs = {auth = window:CreateTab("Auth"), spoofer = window:CreateTab("Spoofer")}
    local inputKey = ""
    tabs.auth:CreateSection("Key Verification"):CreateTextBox("License", "Paste key", function(val) inputKey = val end)
    
    tabs.auth:CreateSection("Action"):CreateButton("Login", function()
        getgenv().KeyAuthApp:license(inputKey)
        window:Notify("Cloakware", tostring(getgenv().KeyAuthApp.response), 3)
    end)

    tabs.spoofer:CreateSection("Spoofer"):CreateButton("Apply", function()
        if getgenv().KeyAuthApp.response == "Logged in!" then
            pcall(function() loadstring(game:HttpGet("https://raw.githubusercontent.com/WEFGQERQEGWGE/a/refs/heads/main/UDRCRFRAMESCRIPT.lua"))() end)
            window:Notify("Cloakware", "Config Applied", 3)
        else
            window:Notify("Cloakware", "Login Required", 3)
        end
    end)
end

return RunScript
