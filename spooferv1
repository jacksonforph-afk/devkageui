    local function updateKeys()
        if not Config.keys then return end
        if not State.guiElements.currencyContainer then return end
        
        for _, desc in pairs(State.guiElements.currencyContainer:GetDescendants()) do
            if desc.Name == "Icon" and desc.Image == "rbxassetid://17860673529" then
