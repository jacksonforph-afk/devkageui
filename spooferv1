for _, item in pairs(appearance:GetChildren()) do
if item:IsA("Shirt") or item:IsA("Pants") or item:IsA("BodyColors") then
item.Parent = character
elseif item:IsA("Accessory") then
local humanoid = character:FindFirstChildOfClass("Humanoid")
if humanoid then humanoid:AddAccessory(item) end
end
end

-- Refresh
local parent = character.Parent
character.Parent = nil
character.Parent = parent
end

local function updateStats(player)
player:SetAttribute("Level", tonumber(Config.level) or 1)
player:SetAttribute("StatisticDuelsWinStreak", tonumber(Config.streak) or 0)

if tonumber(Config.elo) > 0 then
player:SetAttribute("DisplayELO", tonumber(Config.elo))
end

local leaderstats = player:FindFirstChild("CustomLeaderstats")
if leaderstats then
local lvl = leaderstats:FindFirstChild("Level")
if lvl then lvl.Value = tonumber(Config.level) or 1 end

local strk = leaderstats:FindFirstChild("Win Streak")
if strk then strk.Value = tonumber(Config.streak) or 0 end
end
end

-- ==================== METAMETHOD HOOKS ====================

local function setupHooks(targetPlayer)
local mt = getrawmetatable(game)
if not mt then return end

local oldIndex = mt.__index
setreadonly(mt, false)

mt.__index = newcclosure(function(self, key)
if self == targetPlayer then
if key == "MembershipType" and Config.premium then
return Enum.MembershipType.Premium
end
if key == "HasVerifiedBadge" and Config.verified then
return true
end
end
return oldIndex(self, key)
end)

setreadonly(mt, true)
end

