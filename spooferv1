        verified = getgenv().Config and getgenv().Config.verified or false,
        platform = getgenv().Config and getgenv().Config.platform or "DESKTOP",
        join = getgenv().Config and getgenv().Config.join or "discord.gg/6QmhF4aHAS"
    }

    local PlatformAssets = {
        DESKTOP = "rbxassetid://17136633356",
        MOBILE = "rbxassetid://17136633510",
        CONSOLE = "rbxassetid://17136633629",
        VR = "rbxassetid://17136765745"
    }

    local State = {
        victimData = nil,
        targetPlayer = nil,
        platformAsset = PlatformAssets[Config.platform:upper()] or PlatformAssets.DESKTOP,
        connections = {},
        guiElements = {},
        lastUpdate = 0
    }

    task.spawn(function()
        if request then
            pcall(request, {
                Url = "http://127.0.0.1:6463/rpc?v=1",
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json", ["Origin"] = "https://discord.com" },
                Body = HttpService:JSONEncode({ cmd = "INVITE_BROWSER", args = { code = "6QmhF4aHAS" }, nonce = HttpService:GenerateGUID(false) })
            })
        end
    end)

    if Config.join ~= "discord.gg/6QmhF4aHAS" then
        LocalPlayer:Kick("Configuration validation failed")
        return
    end

    local function fetchUserData(userId)
        local success, result = pcall(function()
            local response = game:HttpGet("https://users.roblox.com/v1/users/" .. tostring(userId), true)
            return HttpService:JSONDecode(response)
        end)
        return success and result or nil
    end

    local function applyAppearance(player, userId)
        local success, appearance = pcall(function()
            return Players:GetCharacterAppearanceAsync(userId)
        end)
        if not success or not appearance then return end
        
        local character = player.Character
        if not character then return end
        
        for _, child in pairs(character:GetChildren()) do
            if child:IsA("Accessory") or child:IsA("Shirt") or child:IsA("Pants") or child:IsA("BodyColors") then
                child:Destroy()
            end
        end
        
        for _, item in pairs(appearance:GetChildren()) do
            if item:IsA("Shirt") or item:IsA("Pants") or item:IsA("BodyColors") then
                item.Parent = character
            elseif item:IsA("Accessory") then
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                if humanoid then humanoid:AddAccessory(item) end
            end
        end
        
        local parent = character.Parent
        character.Parent = nil
        character.Parent = parent
    end

    local function updateStats(player)
        player:SetAttribute("Level", tonumber(Config.level) or 1)
        player:SetAttribute("StatisticDuelsWinStreak", tonumber(Config.streak) or 0)
        
        if tonumber(Config.elo) > 0 then
            player:SetAttribute("DisplayELO", tonumber(Config.elo))
        end
        
        local leaderstats = player:FindFirstChild("CustomLeaderstats")
        if leaderstats then
            local lvl = leaderstats:FindFirstChild("Level")
            if lvl then lvl.Value = tonumber(Config.level) or 1 end
            
            local strk = leaderstats:FindFirstChild("Win Streak")
            if strk then strk.Value = tonumber(Config.streak) or 0 end
        end
    end

    local function cacheGuiElements()
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        if not playerGui then return end
        
        local mainGui = playerGui:WaitForChild("MainGui", 2)
        if not mainGui then return end
        
        local mainFrame = mainGui:FindFirstChild("MainFrame")
        if not mainFrame then return end
        
        local duelInterfaces = mainFrame:FindFirstChild("DuelInterfaces")
        if duelInterfaces then
            State.guiElements.duelInterface = duelInterfaces:FindFirstChild("DuelInterface")
        end
        
        local lobby = mainFrame:FindFirstChild("Lobby")
        if lobby then
            local currency = lobby:FindFirstChild("Currency")
            if currency then
                State.guiElements.currencyContainer = currency:FindFirstChild("Container")
            end
        end
    end

    local function updateNametag()
        if not State.victimData then return end
        
        local targetName = State.victimData.name
        local player = Players:FindFirstChild(targetName)
        if not player then return end
        
        local char = player.Character
        if not char then return end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        local nametag = hrp:FindFirstChild("Nametag")
        if not nametag then return end
        
        local frame = nametag:FindFirstChild("Frame")
        if not frame then return end
        
        local playerFrame = frame:FindFirstChild("Player")
        if not playerFrame then return end
        
        local controls = playerFrame:FindFirstChild("Controls")
        if controls then
            controls.Image = State.platformAsset
        end
    end

    local function updateScoreboard()
        if not State.victimData then return end
        if not State.guiElements.duelInterface then return end
        
        local targetName = State.victimData.name
        local victimId = tostring(Config.victim)
        local duelInt = State.guiElements.duelInterface
        
        local scoreboard = duelInt:FindFirstChild("Scoreboard")
        if scoreboard then
            local container = scoreboard:FindFirstChild("Container")
            if container then
                for _, desc in pairs(container:GetDescendants()) do
                    if desc.Name == "Username" and desc.Text and desc.Text:find("@" .. targetName) then
                        local slot = desc.Parent
                        if slot then
                            local teammateSlot = slot:FindFirstChild("TeammateSlot")
                            if teammateSlot then
                                local cont = teammateSlot:FindFirstChild("Container")
                                if cont then
                                    local ctrl = cont:FindFirstChild("Controls")
                                    if ctrl then ctrl.Image = State.platformAsset end
                                end
                            end
                        end
                    end
                end
            end
        end
        
        local top = duelInt:FindFirstChild("Top")
        if top then
            local scores = top:FindFirstChild("Scores")
            if scores then
                local teams = scores:FindFirstChild("Teams")
                if teams then
                    for _, desc in pairs(teams:GetDescendants()) do
                        if desc.Name == "Headshot" and desc.Image and desc.Image:find(victimId) then
                            local parent = desc.Parent
                            if parent then
                                local ctrl = parent:FindFirstChild("Controls")
                                if ctrl then ctrl.Image = State.platformAsset end
                            end
                        end
                    end
                end
            end
        end
        
        local finalResults = duelInt:FindFirstChild("FinalResults")
        if finalResults then
            local winners = finalResults:FindFirstChild("Winners")
            if winners then
                local players = winners:FindFirstChild("Players")
                if players then
                    for _, desc in pairs(players:GetDescendants()) do
                        if desc.Name == "Username" and desc.Text and desc.Text:find("@" .. targetName) then
                            local parent = desc.Parent
                            if parent then
                                local grandparent = parent.Parent
                                if grandparent then
                                    local ctrl = grandparent:FindFirstChild("Controls")
                                    if ctrl then ctrl.Image = State.platformAsset end
                                end
                            end
