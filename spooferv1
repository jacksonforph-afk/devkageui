local Config = {
    name = "Devkage's Application",
    ownerid = "7N9mfQfXml",
    secret = "261e3c647b89bcb0d621252189213e280c0c654141557a9cd8d669b38b3cfec1",
    version = "1.0"
}

-- [FINAL EXECUTION BLOCK] --
local function RunScript(Config)
    local lib_url = "https://raw.githubusercontent.com/KeyAuth/new-keyauth-lua-lib/main/library.lua"
    local KeyAuth = loadstring(game:HttpGet(lib_url))()
    local app = KeyAuth.new(Config.name, Config.ownerid, Config.secret, Config.version)
    
    -- Initialize App
    app:init()
    getgenv().KeyAuthApp = app

    -- UI Setup
    local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/nfpw/XXSCRIPT/refs/heads/main/Library/Module.lua"))()
    local window = library:CreateWindow({Color = Color3.fromRGB(255, 255, 255), Keybind = Enum.KeyCode.RightShift}, gethui())
    
    local tabs = {auth = window:CreateTab("Auth"), spoofer = window:CreateTab("Spoofer")}
    local inputKey = ""
    
    tabs.auth:CreateSection("Key"):CreateTextBox("License", "Paste key here", function(val) inputKey = val end)
    tabs.auth:CreateSection("Action"):CreateButton("Login", function()
        app:license(inputKey)
        if app.response == "Logged in!" then
            window:Notify("Cloakware", "Access Granted!", 3)
        else
            window:Notify("Cloakware", "Error: " .. tostring(app.response), 3)
        end
    end)
end

RunScript(Config)
