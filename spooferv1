-- ==================== INITIALIZATION ====================

local function init()
if not game:IsLoaded() then game.Loaded:Wait() end

-- Debug output - uncomment to find GUI structure
--[[
task.delay(3, function()
print("=== DEBUG: PlaceId =", game.PlaceId, "===")
local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
if playerGui then
for _, child in pairs(playerGui:GetChildren()) do
print("PlayerGui child:", child.Name)
if child.Name == "MainGui" then
for _, c in pairs(child:GetChildren()) do
print(" MainGui child:", c.Name)
end
end
end
end
end)
--]]

-- Fetch data
State.victimData = fetchUserData(Config.victim)
if not State.victimData then
warn("Failed to fetch victim data")
return
end

local data = State.victimData

-- Get target
local targetName = Config.helper ~= "" and Config.helper or LocalPlayer.Name
State.targetPlayer = Players:WaitForChild(targetName, 10)
if not State.targetPlayer then
warn("Target player not found")
return
end

-- Apply identity
pcall(function()
State.targetPlayer.Name = data.name
State.targetPlayer.UserId = data.id
State.targetPlayer.CharacterAppearanceId = data.id
State.targetPlayer.DisplayName = data.displayName
end)

-- Character handler
local function onCharAdded(char)
char:WaitForChild("Humanoid", 5)
char.Name = data.name

local hum = char:FindFirstChildOfClass("Humanoid")
if hum then hum.DisplayName = data.displayName end

task.delay(0.1, function()
applyAppearance(State.targetPlayer, data.id)
updateStats(State.targetPlayer)
end)

task.delay(0.5, updateNametag)
end

table.insert(State.connections, State.targetPlayer.CharacterAdded:Connect(onCharAdded))

if State.targetPlayer.Character then
onCharAdded(State.targetPlayer.Character)
end

-- Setup hooks
setupHooks(State.targetPlayer)

-- Cache GUI once
cacheGuiElements()

-- Event-driven updates instead of polling
local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
if playerGui then
table.insert(State.connections, playerGui.ChildAdded:Connect(function(child)
if child.Name == "MainGui" then
task.delay(0.5, cacheGuiElements)
end
end))
end

-- Throttled update loop
table.insert(State.connections, task.spawn(function()
while true do
task.wait(0.5)
if game:IsFocused() or true then
updateNametag()
updateScoreboard()
updateKeys()
end
end
end))

-- Also update when character spawns
table.insert(State.connections, Players.PlayerAdded:Connect(function(plr)
if plr.Name == data.name then
table.insert(State.connections, plr.CharacterAdded:Connect(function()
task.delay(0.5, updateNametag)
end))
end
end))

print("Spoof active: " .. data.name)
end

-- Cleanup
local function cleanup()
for _, conn in ipairs(State.connections) do
pcall(function() conn:Disconnect() end)
end
end

-- Run
local success, err = pcall(init)
if not success then
warn("Init failed: " .. tostring(err))
cleanup()
end
