-- [KEYAUTH INITIALIZATION] --
    task.spawn(function()
        local success, KeyAuth = pcall(function() 
            return loadstring(game:HttpGet("https://raw.githubusercontent.com/KeyAuth/new-keyauth-lua-lib/main/library.lua"))() 
        end)

        if success then
            local app = KeyAuth.new(Config.name, Config.ownerid, Config.secret, Config.version)
            
            -- Debugging the Init
            local initSuccess, err = pcall(function() app:init() end)
            
            if initSuccess then
                getgenv().KeyAuthApp = app
                library:SetWindowName("Cloakhook | Ready")
                window:Notify("Cloakware", "Auth Successful", 3)
            else
                -- THIS WILL PRINT THE REAL ERROR IN CONSOLE
                warn("CRITICAL AUTH ERROR: " .. tostring(err))
                library:SetWindowName("Cloakhook | Error: " .. tostring(err))
                window:Notify("Cloakware", "Auth Error: Check Console (F9)", 5)
            end
        else
            warn("Failed to download library: " .. tostring(KeyAuth))
        end
    end)
