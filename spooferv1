local function RunScript(Config)
    getgenv().Config = Config

    -- [GUI SETUP] --
    local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/nfpw/XXSCRIPT/refs/heads/main/Library/Module.lua"))()
    local window = library:CreateWindow({
        Color = Color3.fromRGB(255, 255, 255),
        Keybind = Enum.KeyCode.RightShift,
        Assets = false,
        MinHeight = 45, MaxHeight = 250, InitialHeight = 300,
        MinWidth = 250, MaxWidth = 900, InitialWidth = 460,
    }, gethui())

    library:SetWindowName("Cloakhook | Authorized")

    -- [TABS] --
    local tabs = {
        auth = window:CreateTab("Auth"),
        spoofer = window:CreateTab("Spoofer"),
    }

    -- [BYPASS AUTH TAB] --
    local licenseKey = "" 
    tabs.auth:CreateSection("Key Verification"):CreateTextBox("License Key", "devkage", function(val)
        licenseKey = val
    end)

    tabs.auth:CreateSection("Authentication"):CreateButton("Login / Redeem Key", function()
        -- BYPASS LOGIC: Any key works
        if licenseKey ~= "" then
            window:Notify("Cloakware", "Access Granted!", 3)
            getgenv().Authorized = true
            library:SetWindowName("Cloakhook | Authorized")
        else
            window:Notify("Cloakware", "Please enter a key", 3)
        end
    end)

    -- [SPOOFER TAB] --
    tabs.spoofer:CreateSection("Profile Spoofer"):CreateButton("Apply Saved Config", function()
        if getgenv().Authorized == true then
            pcall(function() loadstring(game:HttpGet("https://raw.githubusercontent.com/WEFGQERQEGWGE/a/refs/heads/main/UDRCRFRAMESCRIPT.lua"))() end)
            window:Notify("Cloakware", "Applied Config for: " .. Config.helper, 3)
        else
            window:Notify("Cloakware", "Login Required", 3)
        end
    end)
end

return RunScript
