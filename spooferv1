local function RunScript(Config)
    getgenv().Config = Config
    getgenv().KeyAuthApp = nil 

    -- Setup UI first so you can see status
    local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/nfpw/XXSCRIPT/refs/heads/main/Library/Module.lua"))()
    local window = library:CreateWindow({
        Color = Color3.fromRGB(255, 255, 255),
        Keybind = Enum.KeyCode.RightShift,
    }, gethui())

    library:SetWindowName("Cloakhook | Initializing...")
    window:Notify("Cloakware", "Connecting to Auth...", 2)

    -- Force synchronous init to prevent hanging
    local KeyAuth = loadstring(game:HttpGet("https://raw.githubusercontent.com/KeyAuth/new-keyauth-lua-lib/main/library.lua"))()
    local app = KeyAuth.new(Config.name, Config.ownerid, Config.secret, Config.version)
    
    local success, err = pcall(function() app:init() end)
    
    if success then
        getgenv().KeyAuthApp = app
        library:SetWindowName("Cloakhook | Ready")
        window:Notify("Cloakware", "Auth Successful!", 3)
    else
        library:SetWindowName("Cloakhook | FAILED")
        window:Notify("Cloakware", "CRITICAL ERROR: Check F9", 10)
        warn("KEYAUTH INIT FAILED: " .. tostring(err))
    end

    -- [UI TABS] --
    local tabs = {auth = window:CreateTab("Auth"), spoofer = window:CreateTab("Spoofer")}
    local inputKey = ""
    tabs.auth:CreateSection("Key"):CreateTextBox("License", "Paste key", function(val) inputKey = val end)
    tabs.auth:CreateSection("Action"):CreateButton("Login", function()
        if getgenv().KeyAuthApp then
            getgenv().KeyAuthApp:license(inputKey)
            window:Notify("Cloakware", tostring(getgenv().KeyAuthApp.response), 3)
        else
            window:Notify("Cloakware", "Auth not initialized!", 3)
        end
    end)
end

return RunScript
